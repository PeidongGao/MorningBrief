# MorningBrief configuration — example.
#
# Copy this file to `.env` in the project root and fill in the paths for
# your machine. `.env` is git-ignored; only this example is committed.
#
# A leading `~` is expanded. OS environment variables with the same names
# take precedence over this file. Set MORNINGBRIEF_CONFIG to load a config
# file from a different location.

# Required — the repository containing the existing Morning Brief automation
# (prompts, morning-brief.sh). `codex exec` runs with this as its cwd.
MB_CODEX_REPO=~/path/to/your/codex-workspace

# Required — the Obsidian vault the Morning Brief reads (passed via --add-dir).
MB_VAULT_DIR=~/path/to/your/obsidian/vault

# Required — the codex automation-memory directory (passed via --add-dir).
# The workflow stores its previous-run state here.
MB_AUTOMATION_MEMORY_DIR=~/.codex/automations/your-morning-brief-memory

# Optional — defaults shown.
#MB_PROMPT_FILE=<MB_CODEX_REPO>/prompts/reusable/morning-brief-prompt.md
#MB_SESSIONS_ROOT=~/.codex/sessions
#MB_DATA_ROOT=~/Documents/MorningBriefData
#MB_CODEX_BINARY=codex
