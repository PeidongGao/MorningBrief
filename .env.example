# MorningBrief configuration example.
#
# Environment variables override this file. For a packaged installation, put
# the file at the platform user-config location shown by `mb doctor`, or pass
# it explicitly with `mb --config /path/to/config.env doctor`.

# Required: working directory used by `codex exec`.
MB_CODEX_REPO=/path/to/your/codex-workspace

# Required: prompt piped to `codex exec`.
MB_PROMPT_FILE=/path/to/your/prompt.md

# Required: input notes or documents made available to the workflow.
MB_VAULT_DIR=/path/to/your/input-notes

# Required: private operational state initialized with `mb init`.
MB_STATE_DIR=/path/to/your/morningbrief-state

# Optional: durable reports and history index.
#MB_DATA_ROOT=~/Documents/MorningBriefData

# Optional: defaults to `codex` on PATH.
#MB_CODEX_BINARY=codex

# Compatibility: MB_AUTOMATION_MEMORY_DIR is still accepted as the legacy
# name for MB_STATE_DIR.
